<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width">
<title>WeaveVision Analysis {{ result.analysis_id }}</title>
<style>body{font:15px system-ui;max-width:1100px;margin:2rem auto;color:#0f172a}table{border-collapse:collapse;width:100%}th,td{padding:.5rem;border:1px solid #cbd5e1;text-align:left}.notice{background:#fef3c7;padding:1rem}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}img{max-width:100%}@media print{body{margin:.5cm}}</style></head>
<body><h1>WeaveVision Analysis</h1><div class="notice">Anomaly scores are not probabilities. The result supports expert review and does not establish a physical quality grade.</div>
<dl><dt>Analysis ID</dt><dd>{{ result.analysis_id }}</dd><dt>Decision</dt><dd>{{ result.prediction.decision.value }}</dd><dt>Anomaly score / locked threshold</dt><dd>{{ result.prediction.raw_anomaly_score }} / {{ result.threshold.image_threshold if result.threshold else 'NOT_AVAILABLE' }}</dd><dt>Review priority</dt><dd>{{ result.prediction.review_priority.value }}</dd><dt>Model / threshold</dt><dd>{{ result.model.model_id if result.model else 'NOT_READY' }} / {{ result.threshold.threshold_id if result.threshold else 'NOT_READY' }}</dd><dt>Source SHA-256</dt><dd>{{ result.source.sha256 }}</dd></dl>
<h2>Quality gate</h2><p>{{ result.quality_gate.status.value }} — {{ result.quality_gate.reasons|join(', ') }}</p>
<div class="grid">{% if result.artifacts.overlay_path %}<figure><img src="{{ result.artifacts.overlay_path.name }}" alt="Anomaly overlay"><figcaption>Overlay</figcaption></figure>{% endif %}{% if result.artifacts.mask_path %}<figure><img src="{{ result.artifacts.mask_path.name }}" alt="Thresholded anomaly mask"><figcaption>Mask</figcaption></figure>{% endif %}</div>
<h2>Regions</h2><table><thead><tr><th>ID</th><th>Bounding box</th><th>Area ratio</th><th>Mean score</th><th>Peak score</th></tr></thead><tbody>{% for region in result.regions %}<tr><td>{{ region.region_id }}</td><td>{{ region.bbox_xyxy }}</td><td>{{ region.area_ratio }}</td><td>{{ region.mean_anomaly_score }}</td><td>{{ region.max_anomaly_score }}</td></tr>{% endfor %}</tbody></table>
<h2>Timing</h2><p>Total: {{ result.timing_ms.total }} ms</p></body></html>
