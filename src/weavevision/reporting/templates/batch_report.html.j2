<!doctype html><html lang="en"><head><meta charset="utf-8"><title>WeaveVision Batch {{ result.batch_id }}</title><style>body{font:15px system-ui;max-width:1200px;margin:2rem auto}table{border-collapse:collapse;width:100%}th,td{border:1px solid #ccc;padding:.45rem;text-align:left}</style></head><body>
<h1>WeaveVision Batch Report</h1><p>Anomaly scores are not probabilities. Partial failures are listed and are not silently omitted.</p>
<p>Completed: {{ result.results|length }} · Failed: {{ result.failures|length }}</p><table><thead><tr><th>File</th><th>Decision</th><th>Score</th><th>Priority</th><th>Latency ms</th><th>Model</th><th>Threshold</th></tr></thead><tbody>{% for item in result.results %}<tr><td>{{ item.source.filename }}</td><td>{{ item.prediction.decision.value }}</td><td>{{ item.prediction.raw_anomaly_score }}</td><td>{{ item.prediction.review_priority.value }}</td><td>{{ item.timing_ms.total }}</td><td>{{ item.model.model_id if item.model else 'NOT_READY' }}</td><td>{{ item.threshold.threshold_id if item.threshold else 'NOT_READY' }}</td></tr>{% endfor %}</tbody></table>
<h2>Failures</h2><ul>{% for item in result.failures %}<li>{{ item.filename }} — {{ item.error_code }} — {{ item.message }}</li>{% endfor %}</ul></body></html>
